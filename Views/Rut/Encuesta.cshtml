@{
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0" style="border-radius: 15px;">
        <div class="card-body p-5 text-center">
            <h2 style="color: #002147;">Encuesta de Satisfacción del Sistema</h2>
            <p class="text-muted">El sistema detectó que finalizó su interacción con la plataforma RUT.</p>
            <hr />

            <form asp-action="GuardarEncuesta" method="post" class="text-start">
                <div class="mb-4">
                    <label class="fw-bold">1. ¿Qué tan claras fueron las instrucciones proporcionadas?</label>
                    <div class="d-flex justify-content-between mt-2">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="rating" value="Excelente" id="r1" required>
                            <label class="form-check-label" for="r1">Excelente</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="rating" value="Buena" id="r2">
                            <label class="form-check-label" for="r2">Buena</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="rating" value="Regular" id="r3">
                            <label class="form-check-label" for="r3">Regular</label>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="fw-bold">2. ¿Logró completar su trámite en la DIAN exitosamente?</label>
                    <select name="completado" class="form-select mt-2">
                        <option value="si">Sí, sin problemas</option>
                        <option value="no">No, tuve dificultades técnicas</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="fw-bold">3. Comentarios adicionales o sugerencias:</label>
                    <textarea name="comentario" class="form-control mt-2" rows="3" placeholder="Escriba aquí..."></textarea>
                </div>

                <button type="submit" class="btn btn-lg w-100 text-white" style="background-color: #002147;">
                    Enviar Evaluación y Finalizar
                </button>
            </form>
        </div>
    </div>
</div>
@{
    ViewData["Title"] = "Ingresar - Oficios 360";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="card p-5 shadow-lg border-0 text-center bg-white rounded-4" style="max-width: 450px; width: 100%;">
        <div class="mb-4">
            <div class="display-1 text-primary"><i class="bi bi-person-badge-fill" style="color: #001f3f;"></i></div>
            <h3 class="fw-bold mt-2" style="color: #001f3f;">Oficios 360</h3>
            <p class="text-muted small">Módulo de Seguimiento y Control de Prácticas</p>
        </div>

        <form asp-action="Index" method="get">
            <div class="mb-4 text-start">
                <label class="form-label fw-bold text-dark">Identificación del Estudiante</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="bi bi-card-text"></i></span>
                    <input type="text" name="cedula" class="form-control form-control-lg text-center fw-bold"
                           placeholder="Digita tu cédula aquí" required autofocus autocomplete="off" />
                </div>
                <small class="text-muted d-block mt-1 text-center">Ingresa tu documento para cargar tu progreso y horas.</small>
            </div>

            <button type="submit" class="btn btn-lg w-100 fw-bold text-white shadow-sm" style="background: linear-gradient(135deg, #001f3f 0%, #003366 100%);">
                <i class="bi bi-box-arrow-in-right"></i> INGRESAR AL SISTEMA
            </button>
        </form>
    </div>
</div>
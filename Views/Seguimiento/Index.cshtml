@model List<Oficcios360.Models.RegistroActividad>

@{
    ViewData["Title"] = "Seguimiento de Prácticas - Oficios 360";
}

<div class="container">
    <div class="text-white text-center py-4 rounded shadow-sm mb-4 position-relative" style="background: linear-gradient(135deg, #001f3f 0%, #003366 100%);">
        <a asp-action="IngresarCedula" class="btn btn-sm btn-outline-light position-absolute top-50 end-0 translate-middle-y me-4 fw-bold shadow-sm">
            <i class="bi bi-arrow-left-circle"></i> Cambiar Estudiante
        </a>
        <h2 class="fw-bold m-0"><i class="bi bi-clock-history"></i> Módulo de Seguimiento de Práctica</h2>
        <p class="mb-0 mt-1 small opacity-75">Estudiante Activo: <span class="badge bg-light text-dark fw-bold">@ViewBag.CedulaActual</span></p>
    </div>

    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger shadow-sm">@TempData["MensajeError"]</div>
    }
    @if (TempData["MensajeSuccess"] != null)
    {
        <div class="alert alert-success shadow-sm">@TempData["MensajeSuccess"]</div>
    }

    @if (ViewBag.RequiereMeta == true)
    {
        <div class="card p-4 mb-4 border-warning shadow-sm bg-light animate__animated animate__fadeIn">
            <div class="row align-items-center">
                <div class="col-md-8">
                    @if (ViewBag.MetaCompletadaAviso == true)
                    {
                        <h5 class="fw-bold text-success"><i class="bi bi-trophy-fill"></i> ¡Felicidades! Completaste tu meta anterior</h5>
                        <p class="text-muted mb-0">Si necesitas registrar un nuevo ciclo de horas requeridas para este periodo, digítalo a continuación:</p>
                    }
                    else
                    {
                        <h5 class="fw-bold text-dark"><i class="bi bi-flag-fill text-warning"></i> Configuración de Horas Requeridas</h5>
                        <p class="text-muted mb-0">No tienes una meta activa para este período. Por favor, define cuántas horas necesitas cumplir:</p>
                    }
                </div>
                <div class="col-md-4">
                    <form asp-action="ConfigurarMeta" method="post" class="input-group">
                        <input type="hidden" name="cedula" value="@ViewBag.CedulaActual" />
                        <input type="number" name="horasMeta" class="form-control" placeholder="Ej: 40" min="1" max="320" required />
                        <button type="submit" class="btn btn-warning fw-bold text-dark">Establecer Meta</button>
                    </form>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card p-4 mb-4 shadow-sm bg-white animate__animated animate__fadeIn">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="fw-bold text-dark m-0">Mi Progreso de Prácticas</h5>
                <span class="badge bg-primary fs-6">Meta Actual: @ViewBag.HorasRequeridas Horas</span>
            </div>
            <div class="row align-items-center">
                <div class="col-md-9">
                    <div class="progress" style="height: 25px;">
                        <div class="progress-bar bg-success progress-bar-striped progress-bar-animated"
                             role="progressbar"
                             style="width: @ViewBag.Porcentaje%;"
                             aria-valuenow="@ViewBag.Porcentaje"
                             aria-valuemin="0"
                             aria-valuemax="100">
                            @ViewBag.Porcentaje%
                        </div>
                    </div>
                </div>
                <div class="col-md-3 text-end">
                    <span class="fs-5 fw-bold text-success">@ViewBag.TotalHoras / @ViewBag.HorasRequeridas h</span>
                </div>
            </div>
        </div>
    }

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card p-4 shadow-sm h-100 bg-white">
                <h5 class="fw-bold text-primary border-bottom pb-2 mb-3">Registrar Nueva Actividad</h5>
                <form asp-action="RegistrarActividad" method="post">

                    <input type="hidden" name="EstudianteIdentificacion" value="@ViewBag.CedulaActual" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Fecha</label>
                        <input type="date" name="Fecha" class="form-control" required max="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Horas Dedicadas</label>
                        <input type="number" step="0.5" name="HorasDedicadas" class="form-control" placeholder="Ej: 4" required min="0.5" max="24" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Descripción de Actividades</label>
                        <textarea name="Descripcion" class="form-control" rows="3" placeholder="¿Qué tareas realizaste?" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Observaciones (Opcional)</label>
                        <textarea name="Observaciones" class="form-control" rows="2" placeholder="Notas adicionales..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 fw-bold" style="background-color: #001f3f;">
                        <i class="bi bi-plus-circle"></i> GUARDAR ACTIVIDAD
                    </button>
                </form>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card p-4 shadow-sm h-100 bg-white">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
                    <h5 class="fw-bold text-dark m-0">Historial de Horas Registradas</h5>
                    <button class="btn btn-sm btn-outline-danger fw-bold" data-bs-toggle="modal" data-bs-target="#modalReporte">
                        <i class="bi bi-file-pdf"></i> Generar Reporte PDF
                    </button>
                </div>

                <div class="table-responsive" style="max-height: 430px; overflow-y: auto;">
                    <table class="table table-hover align-middle">
                        <thead class="table-dark" style="position: sticky; top: 0; background-color: #212529; z-index: 1;">
                            <tr>
                                <th>Fecha</th>
                                <th>Descripción</th>
                                <th>Horas</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || !Model.Any())
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted py-4">No has registrado actividades para este ciclo todavía.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="text-nowrap">@item.Fecha.ToShortDateString()</td>
                                        <td class="text-wrap">@item.Descripcion</td>
                                        <td class="fw-bold text-success">@item.HorasDedicadas h</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalReporte" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Generación de Informe Oficial</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="card mb-4 border-primary shadow-sm">
                    <div class="card-header bg-primary text-white py-2">
                        <h6 class="mb-0 fw-bold"><i class="bi bi-pen"></i> 1. Cargar la Firma del Tutor</h6>
                    </div>
                    <div class="card-body bg-light">
                        <form asp-action="SubirFirmaTutor" asp-controller="Seguimiento" method="post" enctype="multipart/form-data">
                            <input type="hidden" name="cedula" value="@ViewBag.CedulaActual" />
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Mes del Informe</label>
                                <input type="month" name="periodoMes" class="form-control form-control-sm" required value="@DateTime.Now.ToString("yyyy-MM")" />
                            </div>
                            <div class="mb-3">
                                <label for="archivoFirma" class="form-label small fw-bold">Seleccionar Imagen de Firma:</label>
                                <input class="form-control form-control-sm" type="file" id="archivoFirma" name="archivoFirma" accept="image/*" required>
                            </div>
                            <button type="submit" class="btn btn-sm btn-primary w-100 fw-bold">
                                <i class="bi bi-save"></i> Guardar Firma
                            </button>
                        </form>
                    </div>
                </div>

                <div class="card border-danger shadow-sm">
                    <div class="card-header bg-danger text-white py-2">
                        <h6 class="mb-0 fw-bold"><i class="bi bi-file-earmark-pdf"></i> 2. Descargar Documento</h6>
                    </div>
                    <form asp-action="DescargarPdf" method="get">
                        <input type="hidden" name="cedula" value="@ViewBag.CedulaActual" />
                        <div class="card-body bg-light">
                            <div class="row g-2">
                                <div class="col-6">
                                    <label class="form-label small fw-bold">Fecha Inicio</label>
                                    <input type="date" name="inicio" class="form-control form-control-sm" required />
                                </div>
                                <div class="col-6">
                                    <label class="form-label small fw-bold">Fecha Fin</label>
                                    <input type="date" name="fin" class="form-control form-control-sm" required />
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer bg-white border-0 px-0 pb-0 mt-3">
                            <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                            <button type="submit" class="btn btn-sm btn-danger fw-bold">
                                <i class="bi bi-download"></i> Descargar Reporte PDF
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@model Oficcios360.Models.Estudiante

@{
    ViewData["Title"] = "Registro de Hoja de Vida";
}

<div class="container mt-4" style="max-width: 850px;">
    <h2 class="mb-4 text-primary fw-bold">Diligenciar Hoja de Vida</h2>

    <!-- ALERTA DE CONFIRMACIÓN DE BASE DE DATOS (MENSÁJE SOLICITADO) -->
    @if (TempData["MensajeConfirmacion"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-start border-success border-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-cloud-check-fill fs-3 me-3 text-success"></i>
                <div>
                    <h6 class="mb-0 fw-bold text-success">Persistencia Exitosa</h6>
                    <small>@TempData["MensajeConfirmacion"]</small>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (ViewBag.AlertasValidacion != null)
    {
        <div class="alert alert-danger shadow-sm mb-4">
            <h5 class="fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> Correcciones requeridas:</h5>
            <ul class="mb-0">
                @foreach (var error in (List<string>)ViewBag.AlertasValidacion)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    <form asp-action="ProcesarAccion" method="post" class="card shadow p-4 bg-white">

        <h4 class="text-secondary border-bottom pb-2 fw-bold"><i class="bi bi-person-lines-fill"></i> 1. Datos Personales</h4>
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <label class="form-label fw-bold">Nombres y Apellidos *</label>
                <input asp-for="Nombre" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold">Cédula de Ciudadanía *</label>
                <input asp-for="Identificacion" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold">Lugar y Fecha de Nacimiento *</label>
                <input asp-for="LugarFechaNacimiento" class="form-control" placeholder="Ej: 07 de Mayo de 1992 en Bogotá" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">Sexo *</label>
                <select asp-for="Sexo" class="form-select">
                    <option value="">Seleccione...</option>
                    <option value="Femenino">Femenino</option>
                    <option value="Masculino">Masculino</option>
                    <option value="Otro">Otro</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">Estado Civil *</label>
                <input asp-for="EstadoCivil" class="form-control" placeholder="Soltero, Casado..." />
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold">Dirección de Residencia *</label>
                <input asp-for="Direccion" class="form-control" placeholder="Cll 12 #12-18. Bogotá" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">Teléfono *</label>
                <input asp-for="Telefono" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">E-Mail *</label>
                <input asp-for="Correo" type="email" class="form-control" />
            </div>
        </div>

        <h4 class="text-secondary border-bottom pb-2 fw-bold"><i class="bi bi-chat-left-text-fill"></i> 2. Perfil Profesional</h4>
        <div class="mb-4">
            <textarea asp-for="PerfilProfesional" class="form-control" rows="4">@Model.PerfilProfesional</textarea>
        </div>

        <h4 class="text-secondary border-bottom pb-2 fw-bold d-flex justify-content-between align-items-center">
            <span><i class="bi bi-mortarboard-fill"></i> 3. Formación Académica</span>
            <button type="button" class="btn btn-sm btn-success" onclick="agregarEstudio()">+ Agregar Estudio</button>
        </h4>

        <div id="contenedor-estudios" class="mb-4">
            @if (Model.Formaciones != null && Model.Formaciones.Count > 0)
            {
                @for (int i = 0; i < Model.Formaciones.Count; i++)
                {
                    <div class="row g-2 mb-2 estudio-item">
                        <div class="col-md-5"><input name="Formaciones[@i].Institucion" value="@Model.Formaciones[i].Institucion" class="form-control" required /></div>
                        <div class="col-md-5"><input name="Formaciones[@i].Titulo" value="@Model.Formaciones[i].Titulo" class="form-control" required /></div>
                        <div class="col-md-2"><input name="Formaciones[@i].AnioFin" value="@Model.Formaciones[i].AnioFin" type="number" class="form-control" required /></div>
                    </div>
                }
            }
            else
            {
                <div class="row g-2 mb-2 estudio-item">
                    <div class="col-md-5"><input name="Formaciones[0].Institucion" class="form-control" placeholder="Institución" required /></div>
                    <div class="col-md-5"><input name="Formaciones[0].Titulo" class="form-control" placeholder="Título Obtenido" required /></div>
                    <div class="col-md-2"><input name="Formaciones[0].AnioFin" type="number" class="form-control" placeholder="Año" required /></div>
                </div>
            }
        </div>

        <div class="d-flex justify-content-end gap-2 border-top pt-3">
            <button type="submit" name="botonAccion" value="Guardar" class="btn btn-primary px-4">
                <i class="bi bi-save"></i> Ver Vista Previa
            </button>
        </div>
    </form>
</div>

<script>
    let contadorEstudios = @(Model.Formaciones?.Count > 0 ? Model.Formaciones.Count : 1);
    function agregarEstudio() {
        const contenedor = document.getElementById('contenedor-estudios');
        const nuevaFila = document.createElement('div');
        nuevaFila.className = 'row g-2 mb-2';
        nuevaFila.innerHTML = `
            <div class="col-md-5"><input name="Formaciones[${contadorEstudios}].Institucion" class="form-control" placeholder="Institución" required /></div>
            <div class="col-md-5"><input name="Formaciones[${contadorEstudios}].Titulo" class="form-control" placeholder="Título Obtenido" required /></div>
            <div class="col-md-2"><input name="Formaciones[${contadorEstudios}].AnioFin" type="number" class="form-control" placeholder="Año" required /></div>
        `;
        contenedor.appendChild(nuevaFila);
        contadorEstudios++;
    }
</script>